
.history/


# ============================================
# Keil MDK 项目 .gitignore 模板
# ============================================





# --- 编译生成的中间文件和目标文件 ---
*.o
# Ignore build outputs, intermediate files, and IDE workspace files

# Build directories
Debug/
Release/
build/
f405demo/
DebugConfig/
RTE/

# Object, binary and map files
*.o
*.obj
*.axf
*.elf
*.bin
*.hex
*.map
*.lst
*.sct
*.icf

# Dependency and intermediate files
*.d
*.dep
*.crf

# Assembler, listings, and source-generated files
*.s

# IDE / project files (generated)
*.ewp
*.ewd
*.uvprojx
*.uvoptx
*.lnp

# Logs, reports, and generated HTML
*.html
*.log

# Editor / OS temporary files
.vscode/
.vs/
.idea/
*~
*.swp
*.swo
Thumbs.db

# Generic build folders
Build/

# Keep repository source and hand-written project files
.history/


# Keil/MDK and IDE-specific generated files
# --- 编译生成的中间文件和目标文件 ---
*.o
*.obj
*.d
*.dep
*.crf
*.lst
*.map
*.lnp
*.axf
*.hex
*.bin
*.sct

# --- 其他临时和日志文件 ---
*.bak
*.htm
*.build_log.htm
*.iex
*.plg
*.tra

# Ignore RTE generated files if present
RTE/

# Keep important project files tracked
!*.uvprojx
!*.uvmpw

# Source files (usually tracked)
!*.c
!*.h
!*.s
!*.cpp
!*.inc

# Ignore per-project generated folders under MDK/ARM output
MDK-ARM/**/Debug/
MDK-ARM/**/Release/
MDK-ARM/**/f405demo/

# Local editor settings and history
.vscode/
.vs/
.idea/
.history/